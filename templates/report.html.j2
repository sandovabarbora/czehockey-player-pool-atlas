<script>
  (() => {
    const toc = document.getElementById('toc');
    if (!toc) return;
    const btn = toc.querySelector('.toc-toggle');
    if (!btn) return;
    const KEY = 'atlas-toc-collapsed';
    const apply = (collapsed) => {
      toc.dataset.collapsed = collapsed ? 'true' : 'false';
      btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      btn.setAttribute('aria-label', collapsed ? 'Zobrazit obsah' : 'Skrýt obsah');
    };
    try {
      apply(localStorage.getItem(KEY) === 'true');
    } catch (e) {
      apply(false);
    }
    btn.addEventListener('click', () => {
      const next = toc.dataset.collapsed !== 'true';
      apply(next);
      try { localStorage.setItem(KEY, next ? 'true' : 'false'); } catch (e) {}
    });
  })();
</script>

